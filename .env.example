# ─── Ollama ────────────────────────────────────────────────────────────────────
# OLLAMA_MODEL=llama3
# OLLAMA_BASE_URL=http://localhost:11434

# ─── Vector store ───────────────────────────────────────────────────────────────
# VECTOR_STORE=chroma   # default — no account needed
# VECTOR_STORE=pinecone # requires keys below

# ─── Pinecone (only needed if VECTOR_STORE=pinecone) ───────────────────────────
# PINECONE_API_KEY=your_pinecone_api_key_here
# PINECONE_INDEX_NAME=repoask

# ─── GitHub (only for private repos) ────────────────────────────────────────────
# GITHUB_TOKEN=ghp_your_personal_access_token_here
